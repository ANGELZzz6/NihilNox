<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#001F3D"
                android:centerColor="#00305C"
                android:endColor="#001F3D"
                android:angle="135"/>
            <corners android:radius="14dp"/>
            <stroke android:width="1dp" android:color="#4FC3F7"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#001428"
                android:centerColor="#001F3D"
                android:endColor="#000D1A"
                android:angle="135"/>
            <corners android:radius="14dp"/>
            <stroke android:width="1dp" android:color="#1A5C8B"/>
        </shape>
    </item>
</selector>