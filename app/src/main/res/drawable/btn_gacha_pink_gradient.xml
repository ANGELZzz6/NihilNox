<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#3D0020"
                android:centerColor="#5C0030"
                android:endColor="#3D0020"
                android:angle="135"/>
            <corners android:radius="14dp"/>
            <stroke android:width="1dp" android:color="#FF69B4"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#280015"
                android:centerColor="#3D0020"
                android:endColor="#1A000E"
                android:angle="135"/>
            <corners android:radius="14dp"/>
            <stroke android:width="1dp" android:color="#8B2252"/>
        </shape>
    </item>
</selector>