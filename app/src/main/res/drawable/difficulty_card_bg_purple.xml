<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient android:angle="135"
                android:startColor="#2A0050"
                android:centerColor="#350060"
                android:endColor="#1A0035"/>
            <corners android:radius="14dp"/>
            <stroke android:width="1dp" android:color="#CC44FF"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:angle="135"
                android:startColor="#1A0035"
                android:centerColor="#250045"
                android:endColor="#100020"/>
            <corners android:radius="14dp"/>
            <stroke android:width="1dp" android:color="#6A0DAD"/>
        </shape>
    </item>
</selector>