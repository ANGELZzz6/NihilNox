<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#3D2E00"
                android:centerColor="#5C4500"
                android:endColor="#3D2E00"
                android:angle="135"/>
            <corners android:radius="14dp"/>
            <stroke android:width="1dp" android:color="#FFD700"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#2A1F00"
                android:centerColor="#3D2E00"
                android:endColor="#1A1300"
                android:angle="135"/>
            <corners android:radius="14dp"/>
            <stroke android:width="1dp" android:color="#8B6914"/>
        </shape>
    </item>
</selector>