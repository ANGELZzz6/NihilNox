<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@drawable/back_global">

                <!-- Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="24dp"
                    android:paddingBottom="14dp"
                    android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:letterSpacing="0.15"
                            android:text="NihilNox"
                            android:textColor="#FFFFFF"
                            android:textSize="26sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvMonedas"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🪙 0"
                            android:textColor="#FFD700"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:background="@drawable/btn_nav_gradient"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#2A2A4A"/>

                <!-- Botones de navegación -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="6dp">

                        <Button
                            android:id="@+id/btnIrAMetas"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="5dp"
                            android:text="🎯 Metas"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:background="@drawable/btn_nav_gradient"
                            android:stateListAnimator="@null"/>

                        <Button
                            android:id="@+id/btnColeccion"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:layout_marginStart="5dp"
                            android:layout_marginEnd="5dp"
                            android:text="🗂 Colección"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:background="@drawable/btn_nav_gradient"
                            android:stateListAnimator="@null"/>

                        <Button
                            android:id="@+id/btnPerfil"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:layout_marginStart="5dp"
                            android:text="👤 Perfil"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:background="@drawable/btn_nav_gradient"
                            android:stateListAnimator="@null"/>
                </LinearLayout>

                <!-- RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/charactersRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="4dp"
                    android:clipToPadding="false"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#2A2A4A"/>

                <!-- Sección gacha -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✦  INVOCACIÓN"
                            android:textColor="#FFD700"
                            android:textSize="11sp"
                            android:letterSpacing="0.2"
                            android:textStyle="bold"
                            android:layout_marginBottom="10dp"/>

                        <!-- Fila dorada -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">

                                <Button
                                    android:id="@+id/oneRollButton"
                                    android:layout_width="0dp"
                                    android:layout_height="64dp"
                                    android:layout_weight="1"
                                    android:layout_marginEnd="8dp"
                                    android:text="✦ 1x\n🪙 5"
                                    android:textColor="#FFD700"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    android:background="@drawable/btn_gacha_gold_gradient"
                                    android:stateListAnimator="@null"/>

                                <Button
                                    android:id="@+id/tenRollButton"
                                    android:layout_width="0dp"
                                    android:layout_height="64dp"
                                    android:layout_weight="1"
                                    android:text="✦ 10x\n🪙 45"
                                    android:textColor="#FFD700"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    android:background="@drawable/btn_gacha_gold_gradient"
                                    android:stateListAnimator="@null"/>
                        </LinearLayout>

                        <!-- Fila rosa -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">

                                <Button
                                    android:id="@+id/oneRollFemButton"
                                    android:layout_width="0dp"
                                    android:layout_height="64dp"
                                    android:layout_weight="1"
                                    android:layout_marginEnd="8dp"
                                    android:text="♀ 1x\n🪙 5"
                                    android:textColor="#FF69B4"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    android:background="@drawable/btn_gacha_pink_gradient"
                                    android:stateListAnimator="@null"/>

                                <Button
                                    android:id="@+id/tenRollFemButton"
                                    android:layout_width="0dp"
                                    android:layout_height="64dp"
                                    android:layout_weight="1"
                                    android:text="♀ 10x\n🪙 45"
                                    android:textColor="#FF69B4"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    android:background="@drawable/btn_gacha_pink_gradient"
                                    android:stateListAnimator="@null"/>
                        </LinearLayout>

                        <!-- Fila azul -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                                <Button
                                    android:id="@+id/oneRollMascButton"
                                    android:layout_width="0dp"
                                    android:layout_height="64dp"
                                    android:layout_weight="1"
                                    android:layout_marginEnd="8dp"
                                    android:text="♂ 1x\n🪙 5"
                                    android:textColor="#4FC3F7"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    android:background="@drawable/btn_gacha_blue_gradient"
                                    android:stateListAnimator="@null"/>

                                <Button
                                    android:id="@+id/tenRollMascButton"
                                    android:layout_width="0dp"
                                    android:layout_height="64dp"
                                    android:layout_weight="1"
                                    android:text="♂ 10x\n🪙 45"
                                    android:textColor="#4FC3F7"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    android:background="@drawable/btn_gacha_blue_gradient"
                                    android:stateListAnimator="@null"/>
                        </LinearLayout>
                </LinearLayout>

        </LinearLayout>

        <!-- ── Overlay de carga — encima de todo gracias al FrameLayout ────────── -->
        <LinearLayout
            android:id="@+id/overlayLoading"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#CC000011"
            android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✦ ✦ ✦"
                    android:textColor="#FFD700"
                    android:textSize="32sp"
                    android:layout_marginBottom="16dp"/>

                <ProgressBar
                    android:id="@+id/progressGacha"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="200dp"
                    android:layout_height="8dp"
                    android:indeterminate="true"
                    android:indeterminateTint="#FFD700"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:id="@+id/tvLoadingMensaje"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Invocando personajes..."
                    android:textColor="#FFD700"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Buscando en el multiverso ✨"
                    android:textColor="#6666AA"
                    android:textSize="12sp"
                    android:layout_marginTop="6dp"/>

        </LinearLayout>

</FrameLayout>