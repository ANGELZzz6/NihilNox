<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/back_global">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="24dp"
        android:paddingBottom="14dp"
        android:background="#0D0D1A">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏰  RECORDATORIOS"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"/>

        <TextView
            android:id="@+id/tvResumenRecordatorios"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Metas con recordatorio activo"
            android:textColor="#555577"
            android:textSize="12sp"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A2A4A"/>

    <!-- Sin recordatorios -->
    <TextView
        android:id="@+id/tvSinRecordatorios"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No tienes recordatorios configurados.\nAbre una meta y toca 🔔 para agregar uno."
        android:textColor="#333355"
        android:textSize="14sp"
        android:gravity="center"
        android:padding="32dp"
        android:lineSpacingMultiplier="1.5"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recordatoriosRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp"
        android:paddingBottom="12dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:clipToPadding="false"/>

    <!-- Footer -->
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A2A4A"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0D0D1A"
        android:padding="14dp">

        <Button
            android:id="@+id/btnVolverRecordatorios"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="← Volver"
            android:textColor="#AAAACC"
            android:textSize="13sp"
            android:background="@drawable/btn_nav_gradient"
            android:stateListAnimator="@null"/>

    </LinearLayout>

</LinearLayout>