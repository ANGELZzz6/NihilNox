<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/back_global">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/headerLearn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="#CC121212"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="🧠 Academia"
            android:textColor="#FFD700"
            android:textSize="22sp"
            android:textStyle="bold"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvLearnRacha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔥 0 días"
                android:textColor="#FF6D00"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvLearnTemas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 temas activos"
                android:textColor="#AAAAAA"
                android:textSize="11sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Lista de temas -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLearnTopics"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="12dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/headerLearn"
        app:layout_constraintBottom_toTopOf="@id/btnLearnNuevoTema"/>

    <!-- Estado vacío -->
    <LinearLayout
        android:id="@+id/layoutLearnVacio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/headerLearn"
        app:layout_constraintBottom_toTopOf="@id/btnLearnNuevoTema">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📚"
            android:textSize="64sp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tu academia está vacía"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Crea tu primer tema y la IA\ngenerará tu lección personalizada"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:gravity="center"/>
    </LinearLayout>

    <!-- Botón nuevo tema -->
    <Button
        android:id="@+id/btnLearnNuevoTema"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="+ Nuevo tema"
        android:textColor="#1A1200"
        android:background="@drawable/btn_gold_action"
        android:layout_margin="12dp"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
