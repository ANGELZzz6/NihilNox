<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <TextView
        android:id="@+id/tvTituloIdentidad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/identidad_titulo"
        android:fontFamily="@font/opensauce"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:padding="20dp"/>

    <TextView
        android:id="@+id/tvIdentidadDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/identidad_subtitulo"
        android:fontFamily="@font/opensauce"
        android:textColor="#777777"
        android:textSize="13sp"
        android:paddingHorizontal="20dp"
        android:paddingBottom="24dp"
        android:lineSpacingMultiplier="1.4"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerIdentidades"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="80dp"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAgregarIdentidad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_input_add"
        android:contentDescription="Nueva identidad"
        app:backgroundTint="#FFD700"
        app:tint="#121212"/>

</LinearLayout>
