<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D1A">

    <!-- Barra de navegación -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#1A1A2E"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">

        <ImageButton
            android:id="@+id/btnAtras"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="@android:color/transparent"
            android:tint="#AAAACC"
            android:alpha="0.3"
            android:contentDescription="Atrás"/>

        <ImageButton
            android:id="@+id/btnAdelante"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_media_next"
            android:background="@android:color/transparent"
            android:tint="#AAAACC"
            android:alpha="0.3"
            android:contentDescription="Adelante"/>

        <TextView
            android:id="@+id/tvUrl"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:background="@drawable/search_bar_bg"
            android:textColor="#CCCCFF"
            android:textSize="11sp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:ellipsize="middle"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"/>

        <!-- Botón nueva pestaña -->
        <ImageButton
            android:id="@+id/btnNuevaPestana"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_input_add"
            android:background="@android:color/transparent"
            android:tint="#FFD700"
            android:contentDescription="Nueva pestaña"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🕵️"
            android:textSize="18sp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"/>

        <ImageButton
            android:id="@+id/btnCerrar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="@android:color/transparent"
            android:tint="#FF5555"
            android:contentDescription="Cerrar"/>

    </LinearLayout>

    <!-- Barra de pestañas -->
    <HorizontalScrollView
        android:id="@+id/scrollPestanas"
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:background="#111122"
        android:scrollbars="none"
        android:fillViewport="false">

        <LinearLayout
            android:id="@+id/layoutPestanas"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:gravity="center_vertical"/>

    </HorizontalScrollView>

    <!-- Barra de progreso -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:progressTint="#FFD700"
        android:progressBackgroundTint="#1A1A2E"
        android:visibility="gone"/>

    <!-- Contenedor de WebViews — uno visible a la vez -->
    <FrameLayout
        android:id="@+id/contenedorWebViews"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>