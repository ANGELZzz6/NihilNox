<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvTituloHabitos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/habitos_titulo"
            android:fontFamily="@font/opensauce"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/btnIdentidad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/icono_identidad"
            android:textSize="20sp"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <TextView
            android:id="@+id/btnEstadisticas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/icono_estadisticas"
            android:textSize="20sp"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <ProgressBar
            android:id="@+id/progressDiario"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="6dp"
            android:layout_weight="1"
            android:max="100"
            android:progress="0"
            android:progressTint="#4CAF50"
            android:progressBackgroundTint="#333333"/>

        <TextView
            android:id="@+id/tvProgresoTexto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:fontFamily="@font/opensauce"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:text="0/0"/>

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerHabitos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="80dp"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAgregarHabito"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_margin="16dp"
        android:contentDescription="Agregar hábito"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="#FFD700"
        app:tint="#121212"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

</LinearLayout>