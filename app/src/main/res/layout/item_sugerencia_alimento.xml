<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="14dp" android:paddingEnd="14dp"
    android:paddingTop="10dp" android:paddingBottom="10dp"
    android:background="@drawable/card_info_panel_bg"
    android:layout_marginBottom="2dp">

    <TextView
        android:id="@+id/tvSugerenciaNombre"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="#FFFFFF" android:textSize="13sp"/>

    <TextView
        android:id="@+id/tvSugerenciaCalorias"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textColor="#FFD700" android:textSize="12sp" android:textStyle="bold"/>

</LinearLayout>