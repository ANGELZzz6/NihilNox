<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/back_global">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="24dp"
        android:paddingBottom="14dp"
        android:background="#0D0D1A">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="✦  BLOCK DE NOTAS"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"/>

            <Button
                android:id="@+id/btnToggleDescripcion"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:text="👁️"
                android:textSize="16sp"
                android:background="@drawable/btn_nav_gradient"
                android:stateListAnimator="@null"
                android:layout_marginEnd="8dp"
                android:padding="0dp"/>

            <Button
                android:id="@+id/btnAgregarNota"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:text="+ Nueva"
                android:textColor="#1A1200"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/btn_gacha_gold_gradient"
                android:stateListAnimator="@null"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"/>

        </LinearLayout>

        <!-- Buscador -->
        <EditText
            android:id="@+id/etBuscarNota"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:hint="🔍  Buscar por título o contenido..."
            android:textColor="#FFFFFF"
            android:textColorHint="#444466"
            android:textSize="14sp"
            android:background="@drawable/input_background"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="text"
            android:maxLines="1"
            android:imeOptions="actionSearch"
            android:singleLine="true"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2A4A"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerNotas"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"/>

    <TextView
        android:id="@+id/tvSinNotas"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="No hay notas aún.\nPulsa + Nueva para crear una."
        android:textColor="#444466"
        android:textSize="15sp"
        android:gravity="center"
        android:visibility="gone"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2A4A"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="14dp"
        android:background="#0D0D1A">

        <Button
            android:id="@+id/btnCambiarContrasena"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="🔑 Cambiar clave"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/btn_nav_gradient"
            android:stateListAnimator="@null"
            android:layout_marginEnd="6dp"/>

        <Button
            android:id="@+id/btnExportarPdf"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="📄 Exportar PDF"
            android:textColor="#1A1200"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/btn_gacha_gold_gradient"
            android:stateListAnimator="@null"
            android:layout_marginStart="6dp"/>

    </LinearLayout>

</LinearLayout>