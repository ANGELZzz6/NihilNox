<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/back_global">

    <!-- ── Header ─────────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical"
        android:background="#0D0D1A">

        <!-- Avatar del personaje circular con borde -->
        <FrameLayout
            android:layout_width="52dp"
            android:layout_height="52dp">

            <ImageView
                android:id="@+id/chatPersonajeImagen"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:scaleType="centerCrop"
                android:background="@drawable/avatar_background"/>

        </FrameLayout>

        <!-- Nombre + estado -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <TextView
                android:id="@+id/chatPersonajeNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● En línea"
                android:textColor="#4CAF50"
                android:textSize="11sp"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <!-- Borrar chat -->
        <TextView
            android:id="@+id/btnBorrarChat"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="🗑"
            android:textSize="18sp"
            android:gravity="center"
            android:background="@drawable/btn_nav_gradient"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2A4A"/>

    <!-- ── Mensajes ────────────────────────────────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"/>

    <!-- ── Input ──────────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="14dp"
        android:gravity="center_vertical"
        android:background="#0D0D1A">

        <EditText
            android:id="@+id/inputMensaje"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Mensaje..."
            android:textColor="#FFFFFF"
            android:textColorHint="#444466"
            android:textSize="14sp"
            android:background="@drawable/chat_input_bg"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:inputType="textMultiLine"
            android:maxLines="4"/>

        <Button
            android:id="@+id/btnEnviar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:text="➤"
            android:textColor="#1A1200"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="@drawable/btn_send_bg"
            android:stateListAnimator="@null"
            android:padding="0dp"/>

    </LinearLayout>

</LinearLayout>