<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cardHabito"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    android:background="@drawable/habito_card_bg"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Indicador de estado (barra izquierda) -->
        <View
            android:id="@+id/indicadorEstado"
            android:layout_width="4dp"
            android:layout_height="40dp"
            android:layout_marginEnd="12dp"
            android:background="#555555"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNombreHabito"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/opensauce"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvAncla"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/opensauce"
                android:textColor="#777777"
                android:textSize="11sp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tvRacha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/opensauce"
                android:textColor="#AAAAAA"
                android:textSize="12sp"/>

        </LinearLayout>

        <!-- Botón completar -->
        <TextView
            android:id="@+id/btnCompletar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="○"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <!-- Botón eliminar -->
        <TextView
            android:id="@+id/btnEliminar"
            android:layout_width="36dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="✕"
            android:textColor="#555555"
            android:textSize="16sp"
            android:layout_marginStart="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"/>

    </LinearLayout>

    <!-- Mensaje de alerta (visible solo en EN_RIESGO / ROTA) -->
    <TextView
        android:id="@+id/tvAlerta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:fontFamily="@font/opensauce"
        android:textSize="11sp"
        android:visibility="gone"/>

    <LinearLayout
        android:id="@+id/layoutNotificacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvHoraNotif"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/opensauce"
            android:textColor="#FFD700"
            android:textSize="12sp"
            android:text="@string/sin_recordatorio"/>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchNotif"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:thumbTint="#FFD700"
            android:trackTint="#3A3A3A"/>

    </LinearLayout>

</LinearLayout>