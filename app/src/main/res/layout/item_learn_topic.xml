<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/difficulty_card_bg"
    android:padding="16dp"
    android:layout_marginBottom="10dp"
    android:clipChildren="false"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tvTopicCategoria"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFD700"
            android:textSize="11sp"
            android:background="@drawable/chip_categoria_bg"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tvTopicRacha"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="#FF6D00"
            android:textSize="12sp"
            android:gravity="end"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvTopicTitulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="17sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/tvTopicDescripcion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#AAAAAA"
        android:textSize="13sp"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginBottom="12dp"/>

    <!-- Barra de dominio -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <ProgressBar
            android:id="@+id/progressTopicDominio"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="6dp"
            android:progressTint="#88FFAA"
            android:progressBackgroundTint="#333355"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tvTopicDominioPct"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#88FFAA"
            android:textSize="12sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Botones -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnTopicEstudiar"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="36dp"
            android:text="📖 Estudiar"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_games_gradient"
            android:layout_marginEnd="6dp"/>

        <Button
            android:id="@+id/btnTopicQuiz"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="36dp"
            android:text="❓ Quiz"
            android:textSize="12sp"
            android:textColor="#1A1200"
            android:background="@drawable/btn_gold_action"/>

        <Button
            android:id="@+id/btnTopicEliminar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="🗑"
            android:textSize="14sp"
            android:background="@drawable/difficulty_card_bg_orange"
            android:padding="0dp"
            android:layout_marginStart="6dp"/>
    </LinearLayout>
</LinearLayout>
