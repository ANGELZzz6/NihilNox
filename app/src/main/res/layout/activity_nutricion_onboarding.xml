<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/back_global"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp">

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🥗 Configuración Nutricional"
            android:textColor="#FFD700"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Completa tu perfil para calcular tus calorías y macros personalizados."
            android:textColor="#6666AA"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="28dp"/>

        <!-- Peso -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Peso (kg)" android:textColor="#AAAACC" android:textSize="13sp"
            android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/etPeso"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:hint="Ej: 75.5" android:textColorHint="#333355"
            android:textColor="#FFFFFF" android:textSize="15sp"
            android:background="@drawable/btn_nav_gradient"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:inputType="numberDecimal" android:maxLines="1"
            android:layout_marginBottom="16dp"/>

        <!-- Altura -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Altura (cm)" android:textColor="#AAAACC" android:textSize="13sp"
            android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/etAltura"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:hint="Ej: 175" android:textColorHint="#333355"
            android:textColor="#FFFFFF" android:textSize="15sp"
            android:background="@drawable/btn_nav_gradient"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:inputType="number" android:maxLines="1"
            android:layout_marginBottom="16dp"/>

        <!-- Edad -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Edad" android:textColor="#AAAACC" android:textSize="13sp"
            android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/etEdad"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:hint="Ej: 22" android:textColorHint="#333355"
            android:textColor="#FFFFFF" android:textSize="15sp"
            android:background="@drawable/btn_nav_gradient"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:inputType="number" android:maxLines="1"
            android:layout_marginBottom="16dp"/>

        <!-- Sexo -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Sexo biológico" android:textColor="#AAAACC" android:textSize="13sp"
            android:layout_marginBottom="8dp"/>
        <RadioGroup android:id="@+id/rgSexo"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="16dp">
            <RadioButton android:id="@+id/rbHombre"
                android:layout_width="0dp" android:layout_height="48dp"
                android:layout_weight="1" android:text="♂ Hombre"
                android:textColor="#FFFFFF" android:buttonTint="#FFD700"
                android:checked="true"/>
            <RadioButton android:id="@+id/rbMujer"
                android:layout_width="0dp" android:layout_height="48dp"
                android:layout_weight="1" android:text="♀ Mujer"
                android:textColor="#FFFFFF" android:buttonTint="#FF69B4"/>
        </RadioGroup>

        <!-- Objetivo -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="¿Cuál es tu objetivo?" android:textColor="#AAAACC" android:textSize="13sp"
            android:layout_marginBottom="6dp"/>
        <Spinner android:id="@+id/spinnerObjetivo"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:background="@drawable/btn_nav_gradient"
            android:paddingStart="12dp"
            android:layout_marginBottom="16dp"/>

        <!-- Nivel de actividad -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Nivel de actividad física" android:textColor="#AAAACC" android:textSize="13sp"
            android:layout_marginBottom="6dp"/>
        <Spinner android:id="@+id/spinnerActividad"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:background="@drawable/btn_nav_gradient"
            android:paddingStart="12dp"
            android:layout_marginBottom="32dp"/>

        <!-- Botón -->
        <Button android:id="@+id/btnOnboardingSiguiente"
            android:layout_width="match_parent" android:layout_height="58dp"
            android:text="Calcular mis macros ✦"
            android:textColor="#1A1200" android:textSize="16sp" android:textStyle="bold"
            android:background="@drawable/btn_gacha_gold_gradient"
            android:stateListAnimator="@null"/>

    </LinearLayout>
</ScrollView>