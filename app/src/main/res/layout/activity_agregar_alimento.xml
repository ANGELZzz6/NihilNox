<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/back_global"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingTop="24dp" android:paddingBottom="32dp">

        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="➕ Agregar alimento"
            android:textColor="#FFD700" android:textSize="20sp" android:textStyle="bold"
            android:layout_marginBottom="20dp"/>

        <!-- Búsqueda -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Buscar alimento" android:textColor="#AAAACC" android:textSize="12sp"
            android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/etBusquedaAlimento"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:hint="Ej: pollo, arroz, huevo..."
            android:textColorHint="#333355" android:textColor="#FFFFFF"
            android:background="@drawable/btn_nav_gradient"
            android:paddingStart="14dp" android:paddingEnd="14dp"
            android:inputType="text" android:maxLines="1"/>

        <TextView android:id="@+id/tvCargandoBusqueda"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🔍 Buscando en Open Food Facts..."
            android:textColor="#6666AA" android:textSize="11sp"
            android:visibility="gone" android:layout_marginTop="4dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerSugerencias"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:visibility="gone" android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp" android:nestedScrollingEnabled="false"/>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#2A2A4A" android:layout_marginVertical="16dp"/>

        <!-- OCR -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="📸 Escanear tabla nutricional"
            android:textColor="#FFD700" android:textSize="13sp" android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp">
            <Button android:id="@+id/btnEscanearFoto"
                android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_marginEnd="8dp"
                android:text="📷 Cámara" android:textColor="#FFFFFF" android:textSize="13sp"
                android:background="@drawable/btn_nav_gradient"
                android:stateListAnimator="@null"/>
            <Button android:id="@+id/btnDesdeGaleria"
                android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1"
                android:text="🖼 Galería" android:textColor="#FFFFFF" android:textSize="13sp"
                android:background="@drawable/btn_nav_gradient"
                android:stateListAnimator="@null"/>
        </LinearLayout>

        <TextView android:id="@+id/tvOcrResultado"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="" android:textColor="#4FC3F7" android:textSize="12sp"
            android:visibility="gone" android:layout_marginBottom="8dp"
            android:lineSpacingMultiplier="1.3"/>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#2A2A4A" android:layout_marginVertical="16dp"/>

        <!-- ✨ Estimación IA -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="✨ Estimar macros con IA"
            android:textColor="#FFD700" android:textSize="13sp" android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Escribe el nombre del plato y la cantidad, luego presiona Estimar"
            android:textColor="#8888AA" android:textSize="11sp"
            android:layout_marginBottom="8dp"/>

        <Button android:id="@+id/btnEstimarIA"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:text="✨ Estimar con IA"
            android:textColor="#FFFFFF" android:textSize="13sp"
            android:background="@drawable/btn_nav_gradient"
            android:stateListAnimator="@null"
            android:layout_marginBottom="4dp"/>

        <TextView android:id="@+id/tvEstimacionInfo"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FF8C00" android:textSize="11sp"
            android:visibility="gone"
            android:layout_marginBottom="8dp"/>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#2A2A4A" android:layout_marginVertical="16dp"/>

        <!-- Formulario manual -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="✏️ Datos del alimento"
            android:textColor="#FFD700" android:textSize="13sp" android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <!-- Nombre -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Nombre *" android:textColor="#AAAACC" android:textSize="12sp"
            android:layout_marginBottom="4dp"/>
        <EditText android:id="@+id/etNombreAlimento"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:hint="Ej: Pechuga de pollo"
            android:textColorHint="#333355" android:textColor="#FFFFFF"
            android:background="@drawable/btn_nav_gradient"
            android:paddingStart="14dp" android:paddingEnd="14dp"
            android:inputType="textCapSentences" android:maxLines="1"
            android:layout_marginBottom="12dp"/>

        <!-- Cantidad y unidad -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Cantidad *" android:textColor="#AAAACC" android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etCantidad"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:hint="100" android:textColorHint="#333355" android:textColor="#FFFFFF"
                    android:background="@drawable/btn_nav_gradient"
                    android:paddingStart="14dp" android:paddingEnd="14dp"
                    android:inputType="numberDecimal" android:maxLines="1"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Unidad" android:textColor="#AAAACC" android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>
                <Spinner android:id="@+id/spinnerUnidad"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/btn_nav_gradient"
                    android:paddingStart="10dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Calorías -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Calorías (kcal) *" android:textColor="#AAAACC" android:textSize="12sp"
            android:layout_marginBottom="4dp"/>
        <EditText android:id="@+id/etCalorias"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:hint="0" android:textColorHint="#333355" android:textColor="#FFD700"
            android:background="@drawable/btn_nav_gradient"
            android:paddingStart="14dp" android:paddingEnd="14dp"
            android:inputType="number" android:maxLines="1"
            android:layout_marginBottom="12dp"/>

        <!-- Macros en grid 2x2 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Proteína (g)" android:textColor="#4FC3F7" android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etProteina"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:hint="0" android:textColorHint="#333355" android:textColor="#4FC3F7"
                    android:background="@drawable/btn_nav_gradient"
                    android:paddingStart="14dp" android:paddingEnd="14dp"
                    android:inputType="numberDecimal" android:maxLines="1"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Carbohidratos (g)" android:textColor="#FFD700" android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etCarbos"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:hint="0" android:textColorHint="#333355" android:textColor="#FFD700"
                    android:background="@drawable/btn_nav_gradient"
                    android:paddingStart="14dp" android:paddingEnd="14dp"
                    android:inputType="numberDecimal" android:maxLines="1"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Grasas (g)" android:textColor="#FF69B4" android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etGrasas"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:hint="0" android:textColorHint="#333355" android:textColor="#FF69B4"
                    android:background="@drawable/btn_nav_gradient"
                    android:paddingStart="14dp" android:paddingEnd="14dp"
                    android:inputType="numberDecimal" android:maxLines="1"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Fibra (g)" android:textColor="#69FF87" android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etFibra"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:hint="0" android:textColorHint="#333355" android:textColor="#69FF87"
                    android:background="@drawable/btn_nav_gradient"
                    android:paddingStart="14dp" android:paddingEnd="14dp"
                    android:inputType="numberDecimal" android:maxLines="1"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Azúcares -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Azúcares (g)" android:textColor="#FF8C00" android:textSize="12sp"
            android:layout_marginBottom="4dp"/>
        <EditText android:id="@+id/etAzucares"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:hint="0" android:textColorHint="#333355" android:textColor="#FF8C00"
            android:background="@drawable/btn_nav_gradient"
            android:paddingStart="14dp" android:paddingEnd="14dp"
            android:inputType="numberDecimal" android:maxLines="1"
            android:layout_marginBottom="12dp"/>

        <!-- Categoría -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Categoría" android:textColor="#AAAACC" android:textSize="12sp"
            android:layout_marginBottom="4dp"/>
        <Spinner android:id="@+id/spinnerCategoriaAlimento"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:background="@drawable/btn_nav_gradient"
            android:paddingStart="10dp" android:layout_marginBottom="24dp"/>

        <!-- Botones -->
        <Button android:id="@+id/btnGuardarAlimento"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:text="✅ Guardar alimento"
            android:textColor="#1A1200" android:textSize="15sp" android:textStyle="bold"
            android:background="@drawable/btn_gacha_gold_gradient"
            android:stateListAnimator="@null" android:layout_marginBottom="8dp"/>

        <Button android:id="@+id/btnVolverAgregar"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="← Volver"
            android:textColor="#AAAACC" android:textSize="13sp"
            android:background="@drawable/btn_nav_gradient"
            android:stateListAnimator="@null"/>

    </LinearLayout>
</ScrollView>