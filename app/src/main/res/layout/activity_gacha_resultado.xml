<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <!-- Fondo con partículas / estrellas decorativas -->
    <View
        android:id="@+id/fondoEstrellas"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0A0A0A"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="12dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvTituloResultado"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="✦ RESULTADO"
                android:textColor="#FFD700"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="0.2"/>

            <!-- Contador personaje actual / total -->
            <TextView
                android:id="@+id/tvContador"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 / 10"
                android:textColor="#666666"
                android:textSize="14sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1E1E1E"/>

        <!-- Zona central: un personaje grande revelado -->
        <FrameLayout
            android:id="@+id/framePersonajeCentral"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center">

            <!-- Glow de fondo según rareza -->
            <View
                android:id="@+id/viewGlowFondo"
                android:layout_width="260dp"
                android:layout_height="360dp"
                android:layout_gravity="center"
                android:alpha="0.15"/>

            <!-- Imagen central grande -->
            <ImageView
                android:id="@+id/ivPersonajeCentral"
                android:layout_width="200dp"
                android:layout_height="280dp"
                android:layout_gravity="center"
                android:scaleType="centerCrop"
                android:alpha="0"/>

            <!-- Borde de rareza sobre la imagen -->
            <View
                android:id="@+id/bordeRarezaCentral"
                android:layout_width="200dp"
                android:layout_height="280dp"
                android:layout_gravity="center"
                android:background="@drawable/borde_rareza"
                android:alpha="0"/>

            <!-- Info del personaje encima abajo -->
            <LinearLayout
                android:id="@+id/layoutInfoCentral"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center|bottom"
                android:layout_marginBottom="60dp"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="@drawable/gradient_bottom_card"
                android:alpha="0">

                <TextView
                    android:id="@+id/tvRarezaCentral"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#FFD700"
                    android:textStyle="bold"
                    android:paddingBottom="4dp"/>

                <TextView
                    android:id="@+id/tvNombreCentral"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:maxLines="2"/>

                <TextView
                    android:id="@+id/tvOrigenCentral"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#AAAAAA"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:paddingTop="2dp"/>

                <TextView
                    android:id="@+id/tvScoreCentral"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#FFD700"
                    android:paddingTop="4dp"/>

            </LinearLayout>

        </FrameLayout>

        <!-- Strip inferior con miniaturas de todos los personajes -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerMiniPersonajes"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:clipToPadding="false"
            android:background="#0F0F0F"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1E1E1E"/>

        <!-- Botones inferiores -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp">

            <Button
                android:id="@+id/btnAnteriorPersonaje"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="◀"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:backgroundTint="#1E1E1E"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnSiguientePersonaje"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="2"
                android:text="SIGUIENTE ▶"
                android:textColor="#121212"
                android:textStyle="bold"
                android:backgroundTint="#FFD700"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnCerrarResultado"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="✕"
                android:textColor="#666666"
                android:textSize="18sp"
                android:backgroundTint="#1E1E1E"/>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>