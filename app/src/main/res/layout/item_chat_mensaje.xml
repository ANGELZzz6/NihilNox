<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="4dp">

    <!-- Mensaje IA (izquierda) -->
    <LinearLayout
        android:id="@+id/layoutIA"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="start"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp"
        android:visibility="gone">

        <TextView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:text="✦"
            android:textColor="#FFD700"
            android:textSize="14sp"
            android:gravity="center"
            android:background="@drawable/card_info_panel_bg"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tvMensajeIA"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="260dp"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:lineSpacingExtra="3dp"
            android:background="@drawable/bubble_ia_bg"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"/>

    </LinearLayout>

    <!-- Mensaje usuario (derecha) -->
    <LinearLayout
        android:id="@+id/layoutUsuario"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="end"
        android:layout_marginBottom="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvMensajeUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="260dp"
            android:textColor="#0D0D1A"
            android:textSize="14sp"
            android:lineSpacingExtra="3dp"
            android:background="@drawable/bubble_usuario_bg"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"/>

    </LinearLayout>

</LinearLayout>