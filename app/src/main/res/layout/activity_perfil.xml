<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/back_global"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Hero del perfil ─────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="36dp"
            android:paddingBottom="24dp"
            android:background="#0D0D1A">

            <FrameLayout
                android:id="@+id/frameAvatar"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tvAvatarEmoji"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:text="👤"
                    android:textSize="52sp"
                    android:gravity="center"
                    android:background="@drawable/avatar_background"/>

                <ImageView
                    android:id="@+id/ivAvatar"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/avatar_background"
                    android:visibility="gone"/>

                <TextView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:text="✏️"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:background="#CC1A1A2E"
                    android:layout_gravity="bottom|end"/>

            </FrameLayout>

            <!-- Nick editable: toca para cambiar -->
            <LinearLayout
                android:id="@+id/layoutNick"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="6dp">

                <TextView
                    android:id="@+id/tvNick"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jugador"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" ✏"
                    android:textColor="#444466"
                    android:textSize="14sp"
                    android:layout_marginStart="4dp"/>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Toca el nombre para editarlo"
                android:textColor="#444466"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2A2A4A"/>

        <!-- ── Monedas ─────────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:background="#0D0D1A">

            <TextView
                android:id="@+id/tvPerfilMonedas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🪙 0"
                android:textColor="#FFD700"
                android:textSize="28sp"
                android:textStyle="bold"
                android:background="@drawable/btn_nav_gradient"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"/>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2A2A4A"/>

        <!-- ── Estadísticas ────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✦  ESTADÍSTICAS"
            android:textColor="#FFD700"
            android:textSize="11sp"
            android:letterSpacing="0.2"
            android:textStyle="bold"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="8dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="80dp"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:layout_marginEnd="6dp" android:background="@drawable/btn_nav_gradient">
                <TextView android:id="@+id/tvPerfilPersonajes" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="🎴  —"
                    android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Personajes" android:textColor="#555577" android:textSize="11sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="80dp"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:layout_marginStart="6dp" android:background="@drawable/btn_nav_gradient">
                <TextView android:id="@+id/tvPerfilAnimes" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="📺  —"
                    android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Animes" android:textColor="#555577" android:textSize="11sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="8dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="80dp"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:layout_marginEnd="6dp" android:background="@drawable/btn_nav_gradient">
                <TextView android:id="@+id/tvPerfilMetasActivas" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="🎯  —"
                    android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Metas activas" android:textColor="#555577" android:textSize="11sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="80dp"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:layout_marginStart="6dp" android:background="@drawable/btn_nav_gradient">
                <TextView android:id="@+id/tvPerfilMejorRacha" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="🔥  —"
                    android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Mejor racha" android:textColor="#555577" android:textSize="11sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/btn_gacha_gold_gradient">

            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="🏆  Metas completadas"
                android:textColor="#FFD700" android:textSize="15sp" android:textStyle="bold"/>

            <TextView android:id="@+id/tvPerfilMetasCompletadas"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textColor="#FFD700" android:textSize="24sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A2A4A"/>

        <!-- ── Accesos ──────────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✦  ACCESOS"
            android:textColor="#FFD700"
            android:textSize="11sp"
            android:letterSpacing="0.2"
            android:textStyle="bold"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="28dp">

            <Button android:id="@+id/btnChatPersonaje"
                android:layout_width="match_parent" android:layout_height="58dp"
                android:text="💬  Chat con personaje" android:textColor="#1A1200"
                android:textSize="15sp" android:textStyle="bold"
                android:background="@drawable/btn_gacha_gold_gradient"
                android:stateListAnimator="@null" android:layout_marginBottom="8dp"/>

            <Button android:id="@+id/btnGaleria"
                android:layout_width="match_parent" android:layout_height="54dp"
                android:text="🎨  Mi Galería" android:textColor="#FFFFFF"
                android:textSize="14sp" android:textStyle="bold"
                android:background="@drawable/btn_nav_gradient"
                android:stateListAnimator="@null" android:layout_marginBottom="8dp"/>

            <Button android:id="@+id/btnReproductor"
                android:layout_width="match_parent" android:layout_height="54dp"
                android:text="🎵  Reproductor" android:textColor="#FFFFFF"
                android:textSize="14sp" android:textStyle="bold"
                android:background="@drawable/btn_nav_gradient"
                android:stateListAnimator="@null" android:layout_marginBottom="8dp"/>

            <Button android:id="@+id/btnBlockNotas"
                android:layout_width="match_parent" android:layout_height="54dp"
                android:text="📝  Block de Notas" android:textColor="#FFFFFF"
                android:textSize="14sp" android:textStyle="bold"
                android:background="@drawable/btn_nav_gradient"
                android:stateListAnimator="@null"/>

            <Button android:id="@+id/btnNutricion"
                android:layout_width="match_parent" android:layout_height="54dp"
                android:text="🥗  Nutrición"
                android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold"
                android:background="@drawable/btn_nav_gradient"
                android:stateListAnimator="@null"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"/>

            <Button android:id="@+id/btnApiKeys"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="⚙ API Keys" android:textColor="#AAAACC"
                android:textSize="13sp" android:background="@drawable/btn_nav_gradient"
                android:stateListAnimator="@null" android:layout_marginTop="8dp"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>