<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/back_global"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- ── Header: Perfil ─────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="48dp">

            <FrameLayout
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvDashAvatarEmoji"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:text="👤"
                    android:textSize="80sp"
                    android:gravity="center"
                    android:background="@drawable/avatar_background"/>

                <ImageView
                    android:id="@+id/ivDashAvatar"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/avatar_background"
                    android:visibility="gone"/>

            </FrameLayout>

            <TextView
                android:id="@+id/tvDashNick"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bienvenido"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Panel de Control"
                android:textColor="#6666AA"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:letterSpacing="0.2"
                android:textAllCaps="true"/>

        </LinearLayout>

        <!-- ── Botones de Navegación ───────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <Button
                android:id="@+id/btnDashGacha"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:text="INVOCACIÓN GACHA"
                android:textColor="#1A1200"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/btn_gacha_gold_gradient"
                android:drawableStart="@drawable/ic_sparkles"
                android:drawablePadding="16dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:stateListAnimator="@null"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnDashReproductor"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Reproductor de Música"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/btn_nav_gradient"
                android:drawableStart="@drawable/ic_music"
                android:drawablePadding="16dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:stateListAnimator="@null"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnDashBlockNotas"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Block de Notas"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/btn_nav_gradient"
                android:drawableStart="@drawable/ic_secure_note"
                android:drawablePadding="16dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:stateListAnimator="@null"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnDashNutricion"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Nutrición &amp; Salud"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/btn_nav_gradient"
                android:drawableStart="@drawable/ic_health"
                android:drawablePadding="16dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:stateListAnimator="@null"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnDashPerfil"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Mi Perfil"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/btn_nav_gradient"
                android:drawableStart="@drawable/ic_user"
                android:drawablePadding="16dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:stateListAnimator="@null"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnDashFall"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="FALL"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/btn_nav_gradient"
                android:drawableStart="@drawable/ic_skull"
                android:drawablePadding="16dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:stateListAnimator="@null"
                android:layout_marginBottom="24dp"/>

            <View
                android:layout_width="100dp"
                android:layout_height="1dp"
                android:background="#2A2A4A"
                android:layout_gravity="center"
                android:layout_marginBottom="24dp"/>

            <Button
                android:id="@+id/btnDashApiKeys"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:text="Configuración API"
                android:textColor="#AAAACC"
                android:textSize="13sp"
                android:background="@drawable/btn_nav_gradient"
                android:drawableStart="@drawable/ic_settings"
                android:drawablePadding="12dp"
                android:stateListAnimator="@null"
                android:layout_marginBottom="32dp"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
