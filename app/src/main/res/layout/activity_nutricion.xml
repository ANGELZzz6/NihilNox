<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/back_global"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#0D0D1A"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:paddingTop="24dp" android:paddingBottom="14dp">

            <TextView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🥗 Nutrición"
                android:textColor="#FFD700"
                android:textSize="22sp" android:textStyle="bold"/>

            <Button android:id="@+id/btnHistorialNutricion"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📅 Historial"
                android:textColor="#888899" android:textSize="11sp"
                android:background="@android:color/transparent"
                android:stateListAnimator="@null"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text=" | " android:textColor="#888899" android:textSize="11sp"/>
            <Button android:id="@+id/btnEditarPerfilNutricion"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⚙ Perfil"
                android:textColor="#888899" android:textSize="11sp"
                android:background="@android:color/transparent"
                android:stateListAnimator="@null"/>
        </LinearLayout>

        <!-- Panel calorías + macros -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_nutricion"
            android:layout_margin="12dp"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvCaloriasHoy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFD700"
                    android:textSize="42sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvCaloriasMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="/ — kcal"
                    android:textColor="#555577"
                    android:textSize="16sp"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="4dp"/>
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressCalorias"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:progressTint="#FFD700"
                android:progressBackgroundTint="#2A2A4A"
                android:max="2000"
                android:layout_marginBottom="16dp"/>

            <!-- Grid de Macros -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:baselineAligned="false">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:background="@drawable/badge_macro" android:padding="10dp" android:layout_margin="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Proteína" android:textColor="#4FC3F7" android:textSize="11sp"/>
                        <TextView android:id="@+id/tvProteina" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 / —g" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold"/>
                        <ProgressBar android:id="@+id/progressProteina" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="4dp" android:progressTint="#4FC3F7" android:progressBackgroundTint="#2A2A4A"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:background="@drawable/badge_macro" android:padding="10dp" android:layout_margin="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Carbos" android:textColor="#FFD700" android:textSize="11sp"/>
                        <TextView android:id="@+id/tvCarbos" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 / —g" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold"/>
                        <ProgressBar android:id="@+id/progressCarbos" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="4dp" android:progressTint="#FFD700" android:progressBackgroundTint="#2A2A4A"/>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:baselineAligned="false">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:background="@drawable/badge_macro" android:padding="10dp" android:layout_margin="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Grasas" android:textColor="#FF69B4" android:textSize="11sp"/>
                        <TextView android:id="@+id/tvGrasas" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 / —g" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold"/>
                        <ProgressBar android:id="@+id/progressGrasas" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="4dp" android:progressTint="#FF69B4" android:progressBackgroundTint="#2A2A4A"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:background="@drawable/badge_macro" android:padding="10dp" android:layout_margin="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fibra" android:textColor="#69FF87" android:textSize="11sp"/>
                        <TextView android:id="@+id/tvFibra" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 / —g" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold"/>
                        <ProgressBar android:id="@+id/progressFibra" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="4dp" android:progressTint="#69FF87" android:progressBackgroundTint="#2A2A4A"/>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/badge_macro" android:padding="10dp" android:layout_margin="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Azúcares" android:textColor="#FF8C00" android:textSize="11sp"/>
                    <TextView android:id="@+id/tvAzucares" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 / —g" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold"/>
                    <ProgressBar android:id="@+id/progressAzucares" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="4dp" android:progressTint="#FF8C00" android:progressBackgroundTint="#2A2A4A"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Botón IA -->
            <Button android:id="@+id/btnAnalizarDia"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="🤖 Analizar mi día con IA"
                android:textColor="#1A1200" android:textSize="14sp" android:textStyle="bold"
                android:background="@drawable/btn_gacha_gold_gradient"
                android:stateListAnimator="@null"
                android:layout_marginTop="12dp"
                android:layout_marginStart="12dp" android:layout_marginEnd="12dp"/>
        </LinearLayout>

        <!-- Comidas del día -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingBottom="28dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_comida_section" android:layout_marginHorizontal="12dp" android:layout_marginVertical="8dp" android:padding="14dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="🌅 Desayuno" android:textColor="#FFD700" android:textSize="15sp" android:textStyle="bold"/>
                    <Button android:id="@+id/btnAgregarDesayuno" android:layout_width="32dp" android:layout_height="32dp" android:text="+" android:textColor="#FFD700" android:textSize="18sp" android:background="@drawable/btn_add_comida" android:stateListAnimator="@null" android:padding="0dp"/>
                </LinearLayout>
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerDesayuno" android:layout_width="match_parent" android:layout_height="wrap_content" android:nestedScrollingEnabled="false"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_comida_section" android:layout_marginHorizontal="12dp" android:layout_marginVertical="8dp" android:padding="14dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="☀️ Almuerzo" android:textColor="#FFD700" android:textSize="15sp" android:textStyle="bold"/>
                    <Button android:id="@+id/btnAgregarAlmuerzo" android:layout_width="32dp" android:layout_height="32dp" android:text="+" android:textColor="#FFD700" android:textSize="18sp" android:background="@drawable/btn_add_comida" android:stateListAnimator="@null" android:padding="0dp"/>
                </LinearLayout>
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerAlmuerzo" android:layout_width="match_parent" android:layout_height="wrap_content" android:nestedScrollingEnabled="false"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_comida_section" android:layout_marginHorizontal="12dp" android:layout_marginVertical="8dp" android:padding="14dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="🌙 Cena" android:textColor="#FFD700" android:textSize="15sp" android:textStyle="bold"/>
                    <Button android:id="@+id/btnAgregarCena" android:layout_width="32dp" android:layout_height="32dp" android:text="+" android:textColor="#FFD700" android:textSize="18sp" android:background="@drawable/btn_add_comida" android:stateListAnimator="@null" android:padding="0dp"/>
                </LinearLayout>
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerCena" android:layout_width="match_parent" android:layout_height="wrap_content" android:nestedScrollingEnabled="false"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_comida_section" android:layout_marginHorizontal="12dp" android:layout_marginVertical="8dp" android:padding="14dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="🍎 Snack" android:textColor="#FFD700" android:textSize="15sp" android:textStyle="bold"/>
                    <Button android:id="@+id/btnAgregarSnack" android:layout_width="32dp" android:layout_height="32dp" android:text="+" android:textColor="#FFD700" android:textSize="18sp" android:background="@drawable/btn_add_comida" android:stateListAnimator="@null" android:padding="0dp"/>
                </LinearLayout>
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerSnack" android:layout_width="match_parent" android:layout_height="wrap_content" android:nestedScrollingEnabled="false"/>
            </LinearLayout>

            <TextView android:id="@+id/tvAnalisisResultado"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text=""
                android:textColor="#CCCCDD" android:textSize="12sp"
                android:visibility="gone"
                android:layout_margin="12dp"
                android:lineSpacingMultiplier="1.4"
                android:background="@drawable/card_nutricion"
                android:padding="14dp"/>

            <Button android:id="@+id/btnVolverNutricion"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="← Volver"
                android:textColor="#AAAACC" android:textSize="13sp"
                android:background="@drawable/btn_nav_gradient"
                android:stateListAnimator="@null"
                android:layout_marginStart="12dp" android:layout_marginEnd="12dp"
                android:layout_marginTop="8dp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>