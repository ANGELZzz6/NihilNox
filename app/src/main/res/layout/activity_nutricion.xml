<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/back_global"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#0D0D1A"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:paddingTop="24dp" android:paddingBottom="14dp">

            <TextView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🥗 Nutrición"
                android:textColor="#FFD700"
                android:textSize="22sp" android:textStyle="bold"/>

            <Button android:id="@+id/btnHistorialNutricion"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="📅 Historial"
                android:textColor="#AAAACC" android:textSize="12sp"
                android:background="@drawable/btn_nav_gradient"
                android:stateListAnimator="@null"
                android:layout_marginEnd="8dp"/>

            <Button android:id="@+id/btnEditarPerfilNutricion"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="⚙ Perfil"
                android:textColor="#AAAACC" android:textSize="12sp"
                android:background="@drawable/btn_nav_gradient"
                android:stateListAnimator="@null"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#2A2A4A"/>

        <!-- Panel calorías + macros -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#0D0D1A"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvCaloriasHoy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFD700"
                    android:textSize="42sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvCaloriasMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="/ — kcal"
                    android:textColor="#555577"
                    android:textSize="16sp"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="4dp"/>
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressCalorias"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:progressTint="#FFD700"
                android:progressBackgroundTint="#2A2A4A"
                android:max="2000"
                android:layout_marginBottom="16dp"/>

            <TextView android:id="@+id/tvProteina"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Proteína  0 / —g"
                android:textColor="#4FC3F7" android:textSize="13sp"
                android:layout_marginBottom="4dp"/>
            <ProgressBar android:id="@+id/progressProteina"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent" android:layout_height="6dp"
                android:progressTint="#4FC3F7" android:progressBackgroundTint="#2A2A4A"
                android:max="150" android:layout_marginBottom="10dp"/>

            <TextView android:id="@+id/tvCarbos"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Carbos    0 / —g"
                android:textColor="#FFD700" android:textSize="13sp"
                android:layout_marginBottom="4dp"/>
            <ProgressBar android:id="@+id/progressCarbos"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent" android:layout_height="6dp"
                android:progressTint="#FFD700" android:progressBackgroundTint="#2A2A4A"
                android:max="300" android:layout_marginBottom="10dp"/>

            <TextView android:id="@+id/tvGrasas"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Grasas    0 / —g"
                android:textColor="#FF69B4" android:textSize="13sp"
                android:layout_marginBottom="4dp"/>
            <ProgressBar android:id="@+id/progressGrasas"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent" android:layout_height="6dp"
                android:progressTint="#FF69B4" android:progressBackgroundTint="#2A2A4A"
                android:max="80" android:layout_marginBottom="10dp"/>

            <TextView android:id="@+id/tvFibra"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Fibra     0 / —g"
                android:textColor="#69FF87" android:textSize="13sp"
                android:layout_marginBottom="4dp"/>
            <ProgressBar android:id="@+id/progressFibra"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent" android:layout_height="6dp"
                android:progressTint="#69FF87" android:progressBackgroundTint="#2A2A4A"
                android:max="38"/>

            <TextView android:id="@+id/tvAzucares"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Azúcares  0 / 50g"
                android:textColor="#FF8C00" android:textSize="13sp"
                android:layout_marginBottom="4dp" android:layout_marginTop="10dp"/>
            <ProgressBar android:id="@+id/progressAzucares"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent" android:layout_height="6dp"
                android:progressTint="#FF8C00" android:progressBackgroundTint="#2A2A4A"
                android:max="50"/>
        </LinearLayout>

        <!-- Botón analizar IA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#0D0D1A"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:paddingTop="8dp" android:paddingBottom="16dp">

            <Button android:id="@+id/btnAnalizarDia"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="🤖 Analizar mi día con IA"
                android:textColor="#1A1200" android:textSize="14sp" android:textStyle="bold"
                android:background="@drawable/btn_gacha_gold_gradient"
                android:stateListAnimator="@null"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#2A2A4A"/>

        <!-- Comidas del día -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp" android:paddingEnd="14dp"
            android:paddingTop="14dp" android:paddingBottom="28dp">

            <!-- Desayuno -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="6dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="🌅 Desayuno"
                    android:textColor="#FFD700" android:textSize="14sp" android:textStyle="bold"/>
                <Button android:id="@+id/btnAgregarDesayuno"
                    android:layout_width="36dp" android:layout_height="36dp"
                    android:text="+" android:textColor="#FFD700" android:textSize="20sp"
                    android:background="@drawable/btn_nav_gradient"
                    android:stateListAnimator="@null" android:padding="0dp"/>
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerDesayuno"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" android:nestedScrollingEnabled="false"/>

            <!-- Almuerzo -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="6dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="☀️ Almuerzo"
                    android:textColor="#FFD700" android:textSize="14sp" android:textStyle="bold"/>
                <Button android:id="@+id/btnAgregarAlmuerzo"
                    android:layout_width="36dp" android:layout_height="36dp"
                    android:text="+" android:textColor="#FFD700" android:textSize="20sp"
                    android:background="@drawable/btn_nav_gradient"
                    android:stateListAnimator="@null" android:padding="0dp"/>
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerAlmuerzo"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" android:nestedScrollingEnabled="false"/>

            <!-- Cena -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="6dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="🌙 Cena"
                    android:textColor="#FFD700" android:textSize="14sp" android:textStyle="bold"/>
                <Button android:id="@+id/btnAgregarCena"
                    android:layout_width="36dp" android:layout_height="36dp"
                    android:text="+" android:textColor="#FFD700" android:textSize="20sp"
                    android:background="@drawable/btn_nav_gradient"
                    android:stateListAnimator="@null" android:padding="0dp"/>
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerCena"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" android:nestedScrollingEnabled="false"/>

            <!-- Snack -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="6dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="🍎 Snack"
                    android:textColor="#FFD700" android:textSize="14sp" android:textStyle="bold"/>
                <Button android:id="@+id/btnAgregarSnack"
                    android:layout_width="36dp" android:layout_height="36dp"
                    android:text="+" android:textColor="#FFD700" android:textSize="20sp"
                    android:background="@drawable/btn_nav_gradient"
                    android:stateListAnimator="@null" android:padding="0dp"/>
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerSnack"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" android:nestedScrollingEnabled="false"/>

            <!-- Resultado análisis IA — debajo de Snack -->
            <TextView android:id="@+id/tvAnalisisResultado"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text=""
                android:textColor="#CCCCDD" android:textSize="12sp"
                android:visibility="gone"
                android:layout_marginBottom="12dp"
                android:lineSpacingMultiplier="1.4"
                android:background="#111133"
                android:padding="12dp"/>

            <Button android:id="@+id/btnVolverNutricion"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="← Volver"
                android:textColor="#AAAACC" android:textSize="13sp"
                android:background="@drawable/btn_nav_gradient"
                android:stateListAnimator="@null"
                android:layout_marginTop="8dp"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>