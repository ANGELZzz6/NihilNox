<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvTituloStats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/estadisticas_titulo"
            android:fontFamily="@font/opensauce"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <!-- Tarjeta resumen global -->
        <LinearLayout
            android:id="@+id/layoutResumen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/habito_card_bg"
                android:padding="16dp"
                android:layout_marginEnd="8dp">
                <TextView
                    android:id="@+id/tvTotalHabitos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:fontFamily="@font/opensauce"
                    android:textColor="#FFD700"
                    android:textSize="28sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="hábitos activos"
                    android:fontFamily="@font/opensauce"
                    android:textColor="#777777"
                    android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/habito_card_bg"
                android:padding="16dp"
                android:layout_marginStart="8dp">
                <TextView
                    android:id="@+id/tvMejorRacha"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:fontFamily="@font/opensauce"
                    android:textColor="#FFD700"
                    android:textSize="28sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="mejor racha global"
                    android:fontFamily="@font/opensauce"
                    android:textColor="#777777"
                    android:textSize="11sp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Gráfico semanal global -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/consistencia_label"
            android:fontFamily="@font/opensauce"
            android:textColor="#777777"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp"/>

        <com.example.colorblend.ui.gacha.GraficoSemanalView
            android:id="@+id/graficoSemanal"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginBottom="24dp"/>

        <!-- Lista de stats por hábito -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/por_habito_label"
            android:fontFamily="@font/opensauce"
            android:textColor="#777777"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp"
            android:visibility="gone"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerStatsHabitos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>
