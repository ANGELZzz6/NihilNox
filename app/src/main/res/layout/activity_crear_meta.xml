<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/back_global">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="14dp"
            android:background="#0D0D1A">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✦  NUEVA META"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"/>

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A2A4A"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <!-- Título -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Título"
                android:textColor="#8888AA"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/inputTitulo"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/chat_input_bg"
                android:textColor="#FFFFFF"
                android:textColorHint="#444466"
                android:hint="Ej: Leer 30 minutos"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="textCapSentences"
                android:layout_marginBottom="16dp"/>

            <!-- Descripción -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Descripción (opcional)"
                android:textColor="#8888AA"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/inputDescripcion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="80dp"
                android:background="@drawable/chat_input_bg"
                android:textColor="#FFFFFF"
                android:textColorHint="#444466"
                android:hint="Describe tu meta..."
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:inputType="textMultiLine|textCapSentences"
                android:gravity="top"
                android:layout_marginBottom="16dp"/>

            <!-- Tipo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tipo de meta"
                android:textColor="#8888AA"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <RadioGroup
                android:id="@+id/radioTipo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <RadioButton
                    android:id="@+id/radioDiaria"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="🔄 Diaria"
                    android:textColor="#FFFFFF"
                    android:buttonTint="#FFD700"
                    android:checked="true"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp"/>

                <RadioButton
                    android:id="@+id/radioAcumulativa"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="📈 Acumulativa"
                    android:textColor="#FFFFFF"
                    android:buttonTint="#FFD700"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp"/>

            </RadioGroup>

            <!-- Objetivo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Objetivo (días / unidades)"
                android:textColor="#8888AA"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/inputObjetivo"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/chat_input_bg"
                android:textColor="#FFFFFF"
                android:textColorHint="#444466"
                android:hint="Ej: 30"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="number"
                android:layout_marginBottom="20dp"/>

            <!-- Días de la semana -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Días habilitados"
                android:textColor="#8888AA"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp"/>

            <CheckBox
                android:id="@+id/cbTodos"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Todos los días"
                android:textColor="#FFD700"
                android:textSize="14sp"
                android:buttonTint="#FFD700"
                android:background="@drawable/btn_nav_gradient"
                android:paddingStart="12dp"
                android:checked="true"
                android:layout_marginBottom="8dp"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="4"
                android:rowCount="2"
                android:layout_marginBottom="20dp">

                <CheckBox android:id="@+id/cbLun" android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_columnWeight="1" android:text="Lun" android:textColor="#AAAACC"
                    android:textSize="13sp" android:buttonTint="#4FC3F7" android:gravity="center"
                    android:layout_margin="3dp" android:background="@drawable/btn_nav_gradient"/>

                <CheckBox android:id="@+id/cbMar" android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_columnWeight="1" android:text="Mar" android:textColor="#AAAACC"
                    android:textSize="13sp" android:buttonTint="#4FC3F7" android:gravity="center"
                    android:layout_margin="3dp" android:background="@drawable/btn_nav_gradient"/>

                <CheckBox android:id="@+id/cbMie" android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_columnWeight="1" android:text="Mié" android:textColor="#AAAACC"
                    android:textSize="13sp" android:buttonTint="#4FC3F7" android:gravity="center"
                    android:layout_margin="3dp" android:background="@drawable/btn_nav_gradient"/>

                <CheckBox android:id="@+id/cbJue" android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_columnWeight="1" android:text="Jue" android:textColor="#AAAACC"
                    android:textSize="13sp" android:buttonTint="#4FC3F7" android:gravity="center"
                    android:layout_margin="3dp" android:background="@drawable/btn_nav_gradient"/>

                <CheckBox android:id="@+id/cbVie" android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_columnWeight="1" android:text="Vie" android:textColor="#AAAACC"
                    android:textSize="13sp" android:buttonTint="#4FC3F7" android:gravity="center"
                    android:layout_margin="3dp" android:background="@drawable/btn_nav_gradient"/>

                <CheckBox android:id="@+id/cbSab" android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_columnWeight="1" android:text="Sáb" android:textColor="#AAAACC"
                    android:textSize="13sp" android:buttonTint="#4FC3F7" android:gravity="center"
                    android:layout_margin="3dp" android:background="@drawable/btn_nav_gradient"/>

                <CheckBox android:id="@+id/cbDom" android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_columnWeight="1" android:text="Dom" android:textColor="#AAAACC"
                    android:textSize="13sp" android:buttonTint="#4FC3F7" android:gravity="center"
                    android:layout_margin="3dp" android:background="@drawable/btn_nav_gradient"/>

            </GridLayout>

            <!-- ── Recordatorio ──────────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recordatorio (opcional)"
                android:textColor="#8888AA"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/card_info_panel_bg"
                android:padding="12dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvHoraSeleccionada"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sin recordatorio"
                        android:textColor="#CCCCDD"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Solo en los días habilitados de la meta"
                        android:textColor="#555577"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp"/>

                </LinearLayout>

                <Button
                    android:id="@+id/btnSeleccionarHora"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="🕐 Hora"
                    android:textColor="#1A1200"
                    android:textSize="12sp"
                    android:background="@drawable/btn_gacha_gold_gradient"
                    android:stateListAnimator="@null"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginStart="8dp"/>

                <Button
                    android:id="@+id/btnQuitarHora"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="✕"
                    android:textColor="#AA4444"
                    android:textSize="14sp"
                    android:background="@drawable/btn_nav_gradient"
                    android:stateListAnimator="@null"
                    android:layout_marginStart="6dp"
                    android:visibility="gone"/>

            </LinearLayout>

            <!-- Botón crear -->
            <Button
                android:id="@+id/btnCrearMeta"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="✦  CREAR META"
                android:textColor="#1A1200"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:background="@drawable/btn_gacha_gold_gradient"
                android:stateListAnimator="@null"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>