<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="#0D0D1A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Zona imagen -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="160dp">

            <ImageView
                android:id="@+id/charImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"/>

            <!-- Gradiente abajo -->
            <View
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_gravity="bottom"
                android:background="@drawable/gradient_bottom_card"/>

            <!-- Tira de rareza arriba -->
            <View
                android:id="@+id/rarezaStripe"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_gravity="top"
                android:background="#FFD700"/>

            <!-- Badge rareza -->
            <TextView
                android:id="@+id/charRareza"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="6dp"
                android:layout_marginTop="8dp"
                android:textSize="9sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/rareza_badge_bg"
                android:paddingStart="5dp"
                android:paddingEnd="5dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:elevation="3dp"/>

            <!-- Score -->
            <TextView
                android:id="@+id/charScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_margin="6dp"
                android:textSize="9sp"
                android:textColor="#FFD700"
                android:textStyle="bold"
                android:elevation="3dp"
                android:shadowColor="#000000"
                android:shadowRadius="3"/>

            <!-- Glow/borde de rareza (solo sobre la imagen, no estira la card) -->
            <View
                android:id="@+id/rarezaBorde"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/borde_rareza"/>

        </FrameLayout>

        <!-- Panel inferior — tamaño fijo para no estirarse -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:orientation="vertical"
            android:background="@drawable/card_info_panel_bg"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/charName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:letterSpacing="0.03"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@drawable/card_divider_gradient"
                android:layout_marginTop="3dp"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:id="@+id/charOrigen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="8sp"
                android:textColor="#8888AA"
                android:maxLines="1"
                android:ellipsize="end"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Glow exterior — DENTRO del CardView para que no estire nada -->
    <View
        android:id="@+id/rarezaGlow"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/card_glow_rareza"
        android:alpha="0.4"/>

</androidx.cardview.widget.CardView>